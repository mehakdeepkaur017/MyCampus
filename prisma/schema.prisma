generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum NoticeType {
  ACADEMIC
  EVENT
  EXAM
  GENERAL
  EMERGENCY
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

model User {
  id         String   @id @default(uuid())
  role       Role     @default(STUDENT)
  name       String
  email      String   @unique
  password   String
  avatar     String?
  department String?
  semester   Int?
  dob        String?
  gender     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attendances Attendance[]
  tasks       Task[]
  notes       Note[]
  notices     Notice[]     @relation("AdminNotices")
  assignmentSubmissions AssignmentSubmission[]
  adminNotes  AdminNote[]  @relation("AdminNotes")
  createdAssignments Assignment[] @relation("AdminAssignments")
  createdTimetables  Timetable[]  @relation("AdminTimetables")
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  subject   String           @default("General")
  date      DateTime
  status    AttendanceStatus
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}

model Task {
  id            String    @id @default(uuid())
  studentId     String
  title         String
  description   String?
  priority      Priority  @default(MEDIUM)
  dueDate       DateTime?
  status        TaskStatus @default(TODO)
  progress      Int        @default(0)
  attachmentUrl String?    @db.Text
  student       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Note {
  id            String   @id @default(uuid())
  studentId     String
  title         String
  content       String   @db.Text
  category      String   @default("General")
  subject       String?
  attachmentUrl String?  @db.Text
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notice {
  id        String     @id @default(uuid())
  adminId   String
  title     String
  content   String     @db.Text
  type      NoticeType @default(GENERAL)
  pinned    Boolean    @default(false)
  department String?
  semester   Int?
  isDemoData Boolean   @default(false)
  admin     User       @relation("AdminNotices", fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model AdminNote {
  id            String   @id @default(uuid())
  adminId       String
  title         String
  content       String   @db.Text
  category      String   @default("General")
  subject       String?
  department    String?
  semester      Int?
  attachmentUrl String?  @db.Text
  isDemoData    Boolean  @default(false)
  admin         User     @relation("AdminNotes", fields: [adminId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Timetable {
  id          String   @id @default(uuid())
  subject     String
  faculty     String
  room        String
  day         String
  startTime   String
  endTime     String
  department  String?
  semester    Int?
  createdById String?
  isDemoData  Boolean  @default(false)
  createdBy   User?    @relation("AdminTimetables", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSettings {
  id                  String   @id @default(uuid())
  attendanceThreshold Int      @default(75)
  updatedAt           DateTime @updatedAt
}

model Assignment {
  id             String    @id @default(uuid())
  title          String
  subject        String
  department     String?
  semester       Int?
  dueDate        DateTime
  documentUrl    String?   @db.Text
  createdById    String?
  isDemoData     Boolean   @default(false)
  createdBy      User?     @relation("AdminAssignments", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  submissions    AssignmentSubmission[]
}

model AssignmentSubmission {
  id             String    @id @default(uuid())
  assignmentId   String
  studentId      String
  submissionUrl  String?   @db.Text
  remarks        String?   @db.Text
  status         String    @default("SUBMITTED")
  submittedAt    DateTime  @default(now())

  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student        User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}
